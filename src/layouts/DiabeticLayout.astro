---
interface Props {
    title?: string;
    patientFacing?: boolean;
}
const { title = 'DiyabetikAyak Takip', patientFacing = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Diyabetik Ayak Hasta Takip Sistemi" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
        :root {
            --font-base: {patientFacing ? '22px' : '18px'};
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            font-size: var(--font-base, 18px);
            background: #f8fafc;
            color: #1e293b;
            min-height: 100vh;
        }
        button, a, input, select, textarea {
            min-height: 48px;
        }
    </style>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
</head>
<body class={patientFacing ? 'patient-ui' : 'doctor-ui'}>
    <slot />
</body>
</html>
