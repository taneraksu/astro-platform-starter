---
import Layout from '../layouts/Layout.astro';
import PreSurgeryChecklist from '../components/PreSurgeryChecklist';
---

<Layout
    title="Pre-Surgery Preparation"
    description="Comprehensive pre-surgery checklist for hip and knee arthroplasty patients"
>
    <div class="page-header">
        <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
            <a href="/" class="hover:text-blue-700 no-underline">Home</a>
            <span>/</span>
            <span class="text-slate-700">Pre-Surgery</span>
        </div>
        <h1 class="page-title">Pre-Surgery Preparation</h1>
        <p class="page-subtitle text-lg">
            Follow this checklist to ensure you're fully prepared for your hip or knee replacement surgery.
        </p>
    </div>

    <!-- Key Info Banner -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="alert alert-info">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
            </svg>
            <div>
                <p class="font-semibold text-sm">Start Early</p>
                <p class="text-sm mt-0.5">Begin preparation 4–6 weeks before your surgery date</p>
            </div>
        </div>
        <div class="alert alert-warning">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
            </svg>
            <div>
                <p class="font-semibold text-sm">Follow Instructions</p>
                <p class="text-sm mt-0.5">Your surgeon's specific instructions override general guidance here</p>
            </div>
        </div>
        <div class="alert alert-success">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
            <div>
                <p class="font-semibold text-sm">Track Progress</p>
                <p class="text-sm mt-0.5">Your checklist progress is saved automatically on this device</p>
            </div>
        </div>
    </div>

    <!-- Interactive Checklist (React) -->
    <PreSurgeryChecklist client:load />

    <!-- Additional Tips -->
    <div class="mt-8 card">
        <h2 class="font-semibold text-slate-900 mb-4">Pre-Hab: Exercises Before Surgery</h2>
        <p class="text-sm text-slate-600 mb-4">
            Research shows that "pre-habilitation" — exercising before surgery — significantly improves recovery outcomes. Aim to strengthen the muscles around your joint in the weeks leading up to surgery.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-blue-50 rounded-lg p-4">
                <h3 class="text-sm font-semibold text-blue-900 mb-2">Hip Pre-Hab</h3>
                <ul class="text-sm text-blue-800 space-y-1 list-disc list-inside">
                    <li>Gluteal strengthening exercises</li>
                    <li>Hip abductor strengthening</li>
                    <li>Stationary cycling (low resistance)</li>
                    <li>Swimming or hydrotherapy</li>
                    <li>Gentle stretching</li>
                </ul>
            </div>
            <div class="bg-teal-50 rounded-lg p-4">
                <h3 class="text-sm font-semibold text-teal-900 mb-2">Knee Pre-Hab</h3>
                <ul class="text-sm text-teal-800 space-y-1 list-disc list-inside">
                    <li>Quadriceps strengthening</li>
                    <li>Straight leg raises</li>
                    <li>Stationary cycling</li>
                    <li>Ankle pumps and heel slides</li>
                    <li>Swimming if comfortable</li>
                </ul>
            </div>
        </div>
        <div class="mt-4">
            <a href="/exercises" class="btn btn-primary btn-sm">View Full Exercise Program →</a>
        </div>
    </div>

    <!-- Questions to Ask Your Surgeon -->
    <div class="mt-6 card">
        <h2 class="font-semibold text-slate-900 mb-4">Questions to Ask Your Surgeon</h2>
        <ul class="space-y-2 text-sm text-slate-700">
            {[
                "What type of implant will you use and why?",
                "What approach will you use (anterior, posterior, lateral for hip)?",
                "What anaesthesia is planned? What are my options?",
                "How long will I be in hospital?",
                "When can I start driving after surgery?",
                "When can I return to work? (depends on job type)",
                "What activities should I avoid long-term with my implant?",
                "What blood clot prevention will I receive?",
                "What are the specific precautions for my surgery?",
                "How will you manage my pain after surgery?",
                "What are the main risks I should know about?",
            ].map(q => (
                <li class="flex items-start gap-2 p-2 rounded-lg hover:bg-slate-50">
                    <span class="text-blue-500 mt-0.5">?</span>
                    <span>{q}</span>
                </li>
            ))}
        </ul>
    </div>
</Layout>
