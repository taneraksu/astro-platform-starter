---
import Layout from '../layouts/Layout.astro';
import PainTracker from '../components/PainTracker';
---

<Layout
    title="Pain & Symptom Tracker"
    description="Track your pain levels, symptoms, and medications after hip or knee replacement surgery"
>
    <div class="page-header">
        <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
            <a href="/" class="hover:text-blue-700 no-underline">Home</a>
            <span>/</span>
            <span class="text-slate-700">Pain Tracker</span>
        </div>
        <h1 class="page-title">Pain & Symptom Tracker</h1>
        <p class="page-subtitle text-lg">
            Log your daily pain levels, medications, and symptoms to track your recovery progress and share with your healthcare team.
        </p>
    </div>

    <!-- Info Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="card">
            <div class="text-2xl mb-2">📈</div>
            <h3 class="font-semibold text-slate-900 mb-1">Track Progress</h3>
            <p class="text-sm text-slate-500">Regular logging helps you and your doctor understand how your recovery is going over time.</p>
        </div>
        <div class="card">
            <div class="text-2xl mb-2">🔒</div>
            <h3 class="font-semibold text-slate-900 mb-1">Private & Local</h3>
            <p class="text-sm text-slate-500">All data is stored privately on your device only. Nothing is uploaded to any server.</p>
        </div>
        <div class="card">
            <div class="text-2xl mb-2">🏥</div>
            <h3 class="font-semibold text-slate-900 mb-1">Share with Your Team</h3>
            <p class="text-sm text-slate-500">Use the Report tab to generate a summary to show your surgeon or GP at appointments.</p>
        </div>
    </div>

    <!-- Pain Scale Reference -->
    <div class="card mb-6">
        <h2 class="font-semibold text-slate-900 mb-3">Numeric Pain Scale Reference</h2>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-200">
                        <th class="text-left py-2 pr-4 text-slate-500 font-medium">Score</th>
                        <th class="text-left py-2 pr-4 text-slate-500 font-medium">Description</th>
                        <th class="text-left py-2 text-slate-500 font-medium">Typical response</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    <tr>
                        <td class="py-2 pr-4"><span class="badge font-bold" style="background:#dcfce7;color:#15803d;">0</span></td>
                        <td class="py-2 pr-4 text-slate-700">No pain</td>
                        <td class="py-2 text-slate-500">Continue activities as normal</td>
                    </tr>
                    <tr>
                        <td class="py-2 pr-4"><span class="badge font-bold" style="background:#fef9c3;color:#854d0e;">1–3</span></td>
                        <td class="py-2 pr-4 text-slate-700">Mild pain — noticeable but not limiting</td>
                        <td class="py-2 text-slate-500">Continue exercises; paracetamol if needed</td>
                    </tr>
                    <tr>
                        <td class="py-2 pr-4"><span class="badge font-bold" style="background:#fed7aa;color:#9a3412;">4–6</span></td>
                        <td class="py-2 pr-4 text-slate-700">Moderate pain — interferes with activity</td>
                        <td class="py-2 text-slate-500">Rest, ice, take prescribed medications</td>
                    </tr>
                    <tr>
                        <td class="py-2 pr-4"><span class="badge font-bold" style="background:#fee2e2;color:#991b1b;">7–9</span></td>
                        <td class="py-2 pr-4 text-slate-700">Severe pain — prevents most activity</td>
                        <td class="py-2 text-slate-500">Contact physiotherapist or GP; review medications</td>
                    </tr>
                    <tr>
                        <td class="py-2 pr-4"><span class="badge font-bold" style="background:#991b1b;color:#ffffff;">10</span></td>
                        <td class="py-2 pr-4 text-slate-700">Worst possible — unbearable</td>
                        <td class="py-2 text-slate-500 font-semibold text-red-600">Seek immediate medical attention</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Warning -->
    <div class="alert alert-warning mb-6 text-sm">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
        </svg>
        <div>
            <p class="font-semibold">When to seek urgent help</p>
            <p class="mt-0.5">Pain score ≥8/10, sudden severe pain, pain with fever, calf pain with swelling (possible DVT), or chest pain/shortness of breath (possible PE) all require immediate medical attention. <a href="/warning-signs" class="font-semibold">See Warning Signs →</a></p>
        </div>
    </div>

    <!-- Interactive Pain Tracker (React) -->
    <PainTracker client:load />
</Layout>
