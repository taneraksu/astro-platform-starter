---
import Layout from '../layouts/Layout.astro';

const faqs = [
    {
        q: "How long will I be in hospital after joint replacement?",
        a: "Most patients stay 2–5 days after hip or knee replacement. Some hospitals offer enhanced recovery pathways where patients go home after 1–2 days. Your stay depends on your health, mobility progress, and home situation."
    },
    {
        q: "When can I drive after surgery?",
        a: "This depends on which leg was operated on and whether it's manual or automatic. Generally: right-leg surgery (automatic car): 6 weeks minimum. Left-leg surgery (automatic): often 4–6 weeks. Right-leg surgery (manual): 8–12 weeks. Always get your surgeon's specific clearance before driving. You must be able to perform an emergency stop safely."
    },
    {
        q: "When can I return to work?",
        a: "Sedentary/desk work: typically 6–8 weeks. Light physical work: 8–12 weeks. Heavy physical work or prolonged standing: 3–6 months or longer. This varies significantly between individuals — discuss with your surgeon."
    },
    {
        q: "What activities can I do long-term with my joint replacement?",
        a: "Encouraged: walking, swimming, cycling, golf, bowls, doubles tennis, dancing, light gardening. Acceptable: hiking, skiing (experienced skiers), elliptical trainer. Discourage: running, jogging, contact sports, squash, heavy impact activities that increase implant wear."
    },
    {
        q: "Will I set off airport metal detectors?",
        a: "Modern metal detectors may detect your implant, though this is less common with newer security systems. Carry your implant card (available from your surgeon) when travelling. If you do set off the detector, ask for alternative screening. This should not prevent you from flying."
    },
    {
        q: "Do I need antibiotics before dental procedures?",
        a: "This is debated and guidance has changed. Current Australian guidelines (AOANJRR/ADA 2021) generally do not recommend routine antibiotic prophylaxis before dental procedures for all joint replacement patients. However, some surgeons still recommend it. Discuss this specifically with your surgeon before any dental work."
    },
    {
        q: "How long does a joint replacement last?",
        a: "Modern implants are designed to last 15–25+ years. Studies show 90%+ of total knee replacements last >20 years, and similar rates for hip replacements. Factors affecting longevity include patient age, weight, activity level, and implant choice. Revision surgery is possible if the implant wears out."
    },
    {
        q: "What is 'revision' surgery?",
        a: "Revision surgery is replacement or repair of a previous joint replacement that has failed. Reasons include wear, loosening, infection, dislocation, or fracture around the implant. Revision surgery is more complex than primary replacement. Rates are about 1–2% at 10 years for primary knee replacements."
    },
    {
        q: "Why does my knee still click or feel different after replacement?",
        a: "Some clicking or subtle sensations are normal with an artificial joint. The new materials behave differently to biological cartilage. Numbness around the incision (especially the outer knee area) is also common and often permanent due to small nerve branches cut during surgery."
    },
    {
        q: "Is it normal to be dissatisfied after knee replacement?",
        a: "About 15–20% of patients report some degree of dissatisfaction after knee replacement, which is higher than for hip replacement (~5%). Reasons include persistent pain, stiffness, or unmet expectations. Outcomes are generally best when surgery is performed for the right indications (severe arthritis with appropriate imaging changes) and with realistic expectations."
    },
];
---

<Layout
    title="Educational Resources"
    description="Learn about orthopaedic arthroplasty — hip and knee replacement procedures, implants, and what to expect"
>
    <div class="page-header">
        <div class="flex items-center gap-2 text-sm text-slate-500 mb-3">
            <a href="/" class="hover:text-blue-700 no-underline">Home</a>
            <span>/</span>
            <span class="text-slate-700">Resources</span>
        </div>
        <h1 class="page-title">Educational Resources</h1>
        <p class="page-subtitle text-lg">
            Understanding your condition and procedure leads to better outcomes. Learn about arthroplasty surgery.
        </p>
    </div>

    <!-- What is Arthroplasty -->
    <div class="card mb-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-xl">🦴</div>
            <h2 class="font-semibold text-slate-900 text-xl">What is Arthroplasty?</h2>
        </div>
        <p class="text-slate-700 mb-4 leading-relaxed">
            <strong>Arthroplasty</strong> means surgical reconstruction or replacement of a joint. <strong>Total arthroplasty</strong> (total joint replacement) involves removing the damaged joint surfaces and replacing them with artificial components made of metal, ceramic, and/or plastic (polyethylene).
        </p>
        <p class="text-slate-700 leading-relaxed">
            The primary goal is to <strong>relieve pain</strong> and <strong>restore function</strong>. Joint replacement is typically considered when:
        </p>
        <ul class="mt-3 space-y-1.5 text-slate-600 text-sm ml-4">
            <li>• Severe arthritis (osteoarthritis, rheumatoid arthritis, or other causes)</li>
            <li>• Conservative treatment has failed (physiotherapy, medications, injections)</li>
            <li>• Pain and disability significantly affecting quality of life</li>
            <li>• Appropriate imaging evidence of severe joint damage</li>
        </ul>
    </div>

    <!-- Hip vs Knee Split -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <!-- Hip Replacement -->
        <div class="card">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-xl">🦴</div>
                <h2 class="font-semibold text-slate-900">Total Hip Replacement (THR)</h2>
            </div>
            <p class="text-sm text-slate-600 mb-4 leading-relaxed">
                In a total hip replacement, the damaged ball-and-socket hip joint is replaced with an artificial implant. The femoral head (ball) is replaced with a metal or ceramic ball on a metal stem inserted into the femur. The acetabulum (socket) is relined with a metal cup and plastic/ceramic liner.
            </p>
            <div class="space-y-3">
                <div class="bg-blue-50 rounded-lg p-3">
                    <p class="text-xs font-semibold text-blue-800 mb-1">Surgical Approaches</p>
                    <ul class="text-xs text-blue-700 space-y-0.5">
                        <li><strong>Posterior:</strong> Most common. Incision at back/side of hip. Historically required hip precautions.</li>
                        <li><strong>Anterior (DAA):</strong> Front of hip. Often faster recovery, fewer precautions. Growing in use.</li>
                        <li><strong>Lateral:</strong> Side approach. Less common.</li>
                    </ul>
                </div>
                <div class="bg-slate-50 rounded-lg p-3">
                    <p class="text-xs font-semibold text-slate-700 mb-1">Implant Fixation</p>
                    <ul class="text-xs text-slate-600 space-y-0.5">
                        <li><strong>Cemented:</strong> Bone cement fixes components. Common in older patients.</li>
                        <li><strong>Cementless:</strong> Components have roughened surface for bone to grow into. Common in younger, active patients.</li>
                        <li><strong>Hybrid:</strong> Cemented stem, cementless cup (or vice versa).</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Knee Replacement -->
        <div class="card">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-teal-100 rounded-lg flex items-center justify-center text-xl">🦵</div>
                <h2 class="font-semibold text-slate-900">Total Knee Replacement (TKR)</h2>
            </div>
            <p class="text-sm text-slate-600 mb-4 leading-relaxed">
                In a total knee replacement, the damaged surfaces of the femur, tibia, and often the patella (kneecap) are replaced with metal and plastic components. A polyethylene (plastic) insert sits between the femoral and tibial components to allow smooth movement.
            </p>
            <div class="space-y-3">
                <div class="bg-teal-50 rounded-lg p-3">
                    <p class="text-xs font-semibold text-teal-800 mb-1">Types of Knee Replacement</p>
                    <ul class="text-xs text-teal-700 space-y-0.5">
                        <li><strong>Total (TKR):</strong> All compartments replaced. Most common.</li>
                        <li><strong>Unicompartmental (UKR):</strong> Only one compartment (medial, lateral, or patellofemoral) replaced. Faster recovery, suitable for limited disease.</li>
                        <li><strong>Revision:</strong> Re-operation on a previous replacement.</li>
                    </ul>
                </div>
                <div class="bg-slate-50 rounded-lg p-3">
                    <p class="text-xs font-semibold text-slate-700 mb-1">Key Difference from Hip</p>
                    <p class="text-xs text-slate-600">
                        Knee replacement often has a longer, more demanding rehabilitation. Regaining knee bend (flexion) and full extension are critical. Results are highly dependent on rehabilitation effort.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Anaesthesia Options -->
    <div class="card mb-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center text-xl">💉</div>
            <h2 class="font-semibold text-slate-900">Anaesthesia Options</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-purple-50 rounded-lg p-4">
                <h3 class="font-semibold text-purple-900 text-sm mb-2">Spinal Anaesthesia</h3>
                <p class="text-xs text-purple-700 leading-relaxed">
                    Injection into the spinal fluid numbs from the waist down. You remain awake (sedation available). Generally preferred for joint replacement — associated with less blood loss, lower DVT risk, and faster recovery. No sore throat or airway risks.
                </p>
            </div>
            <div class="bg-indigo-50 rounded-lg p-4">
                <h3 class="font-semibold text-indigo-900 text-sm mb-2">General Anaesthesia</h3>
                <p class="text-xs text-indigo-700 leading-relaxed">
                    You are fully asleep for the procedure. May be combined with regional nerve blocks for pain control. Suitable when spinal is not possible or patient preference. Associated with slightly higher risk of nausea, sore throat, and cognitive effects in elderly patients.
                </p>
            </div>
            <div class="bg-teal-50 rounded-lg p-4">
                <h3 class="font-semibold text-teal-900 text-sm mb-2">Regional Nerve Blocks</h3>
                <p class="text-xs text-teal-700 leading-relaxed">
                    Often used as an adjunct to either spinal or general anaesthesia. Ultrasound-guided injection numbs specific nerves (e.g. femoral nerve block for knee, fascia iliaca block for hip). Provides excellent post-operative pain control.
                </p>
            </div>
        </div>
    </div>

    <!-- Pain Management -->
    <div class="card mb-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center text-xl">💊</div>
            <h2 class="font-semibold text-slate-900">Pain Management After Surgery</h2>
        </div>
        <p class="text-sm text-slate-600 mb-4">
            Modern multimodal pain management uses several medications together to achieve good pain control with fewer side effects than relying on opioids alone.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
            <div>
                <h3 class="font-medium text-slate-800 mb-2">Common medications used:</h3>
                <ul class="space-y-2 text-slate-600">
                    <li class="flex items-start gap-2">
                        <span class="text-green-500 mt-0.5">•</span>
                        <div><strong>Paracetamol (acetaminophen):</strong> Mainstay — regular dosing reduces opioid need</div>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-green-500 mt-0.5">•</span>
                        <div><strong>NSAIDs</strong> (celecoxib, ibuprofen): Anti-inflammatory; often used short-term post-op</div>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-green-500 mt-0.5">•</span>
                        <div><strong>Opioids</strong> (oxycodone, tramadol): Short-term use for breakthrough pain; aim to wean quickly</div>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-green-500 mt-0.5">•</span>
                        <div><strong>Gabapentinoids</strong> (pregabalin, gabapentin): Help with nerve-type pain; short-term use</div>
                    </li>
                </ul>
            </div>
            <div>
                <h3 class="font-medium text-slate-800 mb-2">Non-medication approaches:</h3>
                <ul class="space-y-2 text-slate-600">
                    <li class="flex items-start gap-2">
                        <span class="text-blue-500 mt-0.5">•</span>
                        <div><strong>Ice therapy:</strong> 15–20 min on joint, several times daily — reduces swelling and pain</div>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-500 mt-0.5">•</span>
                        <div><strong>Elevation:</strong> Reducing dependent oedema (swelling)</div>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-500 mt-0.5">•</span>
                        <div><strong>TENS machine:</strong> Transcutaneous electrical nerve stimulation</div>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-500 mt-0.5">•</span>
                        <div><strong>Hydrotherapy:</strong> Warm water exercise reduces pain and facilitates movement</div>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Complications Overview -->
    <div class="card mb-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center text-xl">⚠️</div>
            <h2 class="font-semibold text-slate-900">Possible Complications</h2>
        </div>
        <p class="text-sm text-slate-600 mb-4">
            Joint replacement is a safe procedure with a low overall complication rate, but as with any major surgery, risks exist. Your surgeon will discuss these with you.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
            <div>
                <h3 class="font-medium text-slate-800 mb-2">Short-term risks:</h3>
                <ul class="space-y-1.5 text-slate-600">
                    <li class="flex items-start gap-2"><span class="badge badge-red text-xs">~1%</span> Deep infection (periprosthetic joint infection)</li>
                    <li class="flex items-start gap-2"><span class="badge badge-yellow text-xs">~1–2%</span> Deep vein thrombosis (DVT)</li>
                    <li class="flex items-start gap-2"><span class="badge badge-yellow text-xs">&lt;0.1%</span> Pulmonary embolism (PE)</li>
                    <li class="flex items-start gap-2"><span class="badge badge-blue text-xs">~2%</span> Hip dislocation (higher with posterior approach)</li>
                    <li class="flex items-start gap-2"><span class="badge badge-blue text-xs">&lt;1%</span> Nerve or vessel injury</li>
                    <li class="flex items-start gap-2"><span class="badge badge-blue text-xs">&lt;1%</span> Periprosthetic fracture</li>
                </ul>
            </div>
            <div>
                <h3 class="font-medium text-slate-800 mb-2">Long-term considerations:</h3>
                <ul class="space-y-1.5 text-slate-600">
                    <li class="flex items-start gap-2"><span class="badge badge-blue text-xs">~1–2%/yr</span> Component wear (polyethylene)</li>
                    <li class="flex items-start gap-2"><span class="badge badge-blue text-xs">~1–3%/10yr</span> Aseptic loosening</li>
                    <li class="flex items-start gap-2"><span class="badge badge-yellow text-xs">~15–20%</span> Patient dissatisfaction (knee replacement)</li>
                    <li class="flex items-start gap-2"><span class="badge badge-blue text-xs">~5%</span> Patient dissatisfaction (hip replacement)</li>
                    <li class="flex items-start gap-2"><span class="badge badge-blue text-xs">common</span> Persistent numbness around incision</li>
                </ul>
            </div>
        </div>
        <div class="mt-4">
            <a href="/warning-signs" class="btn btn-danger btn-sm">View Warning Signs & When to Seek Help →</a>
        </div>
    </div>

    <!-- FAQ Section -->
    <div class="card">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-xl">❓</div>
            <h2 class="font-semibold text-slate-900 text-xl">Frequently Asked Questions</h2>
        </div>
        <div class="space-y-4" id="faq-list">
            {faqs.map((faq, index) => (
                <div class="border border-slate-200 rounded-xl overflow-hidden">
                    <button
                        class="w-full text-left p-4 flex items-start gap-3 hover:bg-slate-50 transition-colors font-medium text-slate-800 text-sm"
                        onclick={`toggleFaq(${index})`}
                        aria-expanded="false"
                        aria-controls={`faq-${index}`}
                    >
                        <span class="text-blue-500 flex-shrink-0 mt-0.5 font-bold">Q.</span>
                        <span class="flex-1">{faq.q}</span>
                        <svg id={`faq-icon-${index}`} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="flex-shrink-0 mt-0.5 transition-transform text-slate-400">
                            <path d="M6 9l6 6 6-6"/>
                        </svg>
                    </button>
                    <div id={`faq-${index}`} class="hidden px-4 pb-4 pt-0">
                        <div class="pl-6 border-l-2 border-blue-200">
                            <p class="text-sm text-slate-600 leading-relaxed">{faq.a}</p>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</Layout>

<script>
    function toggleFaq(index: number) {
        const content = document.getElementById(`faq-${index}`);
        const icon = document.getElementById(`faq-icon-${index}`);
        const btn = content?.previousElementSibling as HTMLButtonElement;

        if (!content) return;
        const isHidden = content.classList.contains('hidden');
        content.classList.toggle('hidden', !isHidden);
        icon?.classList.toggle('rotate-180', isHidden);
        btn?.setAttribute('aria-expanded', String(isHidden));
    }
    (window as any).toggleFaq = toggleFaq;
</script>
