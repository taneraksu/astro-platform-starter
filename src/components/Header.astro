---
const currentPath = Astro.url.pathname;

const navItems = [
    { linkText: 'Dashboard', href: '/' },
    { linkText: 'Pre-Surgery', href: '/pre-surgery' },
    { linkText: 'Recovery', href: '/recovery' },
    { linkText: 'Exercises', href: '/exercises' },
    { linkText: 'Pain Tracker', href: '/pain-tracker' },
    { linkText: 'Resources', href: '/resources' },
    { linkText: 'Warning Signs', href: '/warning-signs' },
];
---

<header class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo / Brand -->
            <a href="/" class="flex items-center gap-2 no-underline group" aria-label="ArthroCare Home">
                <div class="w-8 h-8 bg-blue-700 rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="white" opacity="0"/>
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L12 14.17l7.59-7.59L21 8l-9 9z" fill="white" opacity="0"/>
                        <path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" fill="white"/>
                    </svg>
                </div>
                <div>
                    <span class="font-bold text-blue-800 text-lg leading-none">ArthroCare</span>
                    <span class="block text-xs text-slate-500 leading-none">Arthroplasty Patient App</span>
                </div>
            </a>

            <!-- Desktop Navigation -->
            <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
                {navItems.map((item) => (
                    <a
                        href={item.href}
                        class={`nav-link ${currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? 'nav-link-active' : ''}`}
                    >
                        {item.linkText}
                    </a>
                ))}
            </nav>

            <!-- Emergency button (desktop) -->
            <div class="hidden lg:flex items-center gap-3">
                <a href="/warning-signs" class="btn btn-danger btn-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                    </svg>
                    Emergency
                </a>
            </div>

            <!-- Mobile menu button -->
            <button
                id="mobile-menu-btn"
                class="lg:hidden p-2 rounded-lg text-slate-600 hover:text-blue-700 hover:bg-blue-50 transition-colors"
                aria-label="Toggle mobile menu"
                aria-expanded="false"
            >
                <svg id="menu-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
                <svg id="close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <!-- Mobile Navigation -->
        <nav id="mobile-menu" class="lg:hidden hidden pb-4" aria-label="Mobile navigation">
            <div class="flex flex-col gap-1">
                {navItems.map((item) => (
                    <a
                        href={item.href}
                        class={`nav-link ${currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? 'nav-link-active' : ''}`}
                    >
                        {item.linkText}
                    </a>
                ))}
                <a href="/warning-signs" class="btn btn-danger btn-sm mt-2 w-full">
                    Emergency Info
                </a>
            </div>
        </nav>
    </div>
</header>

<script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    btn?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', isOpen);
        menuIcon?.classList.toggle('hidden', !isOpen);
        closeIcon?.classList.toggle('hidden', isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
    });
</script>
